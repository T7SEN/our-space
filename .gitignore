# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ────────────────────────────────────────────────────────────────────────────
# Dependencies
# ────────────────────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ────────────────────────────────────────────────────────────────────────────
# Build output
# ────────────────────────────────────────────────────────────────────────────
/.next/
/out/
/build
*.tsbuildinfo
next-env.d.ts

# ────────────────────────────────────────────────────────────────────────────
# Testing
# ────────────────────────────────────────────────────────────────────────────
/coverage

# ────────────────────────────────────────────────────────────────────────────
# Logs
# ────────────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ────────────────────────────────────────────────────────────────────────────
# Env files & secrets — DO NOT REMOVE
# ────────────────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
.env.sentry-build-plugin
.sentryclirc

# Android signing / Firebase service accounts
*.jks
*.keystore
*.p12
*.pem
.firebase/
serviceAccountKey.json
google-services.json
GoogleService-Info.plist

# TLS certificates
/certificates/
*.crt
*.key

# ────────────────────────────────────────────────────────────────────────────
# Vercel
# ────────────────────────────────────────────────────────────────────────────
.vercel

# ────────────────────────────────────────────────────────────────────────────
# Serwist / Service worker outputs (regenerated each build)
# ────────────────────────────────────────────────────────────────────────────
public/sw.js
public/sw.js.map
public/sw-*.js
public/sw-*.js.map
public/swe-*.js
public/workbox-*.js
public/workbox-*.js.map

# ────────────────────────────────────────────────────────────────────────────
# Capacitor — native shells are regenerated from capacitor.config.ts
# ────────────────────────────────────────────────────────────────────────────
android/
ios/

# ────────────────────────────────────────────────────────────────────────────
# Stale scaffolding (no longer used; kept ignored to suppress false positives)
# ────────────────────────────────────────────────────────────────────────────
/src/generated/prisma

# ────────────────────────────────────────────────────────────────────────────
# AI tooling — local agent caches & sessions, never shared
# ────────────────────────────────────────────────────────────────────────────
.claude/
.cursor/
.aider*
.continue/

# ────────────────────────────────────────────────────────────────────────────
# Editor & IDE
# ────────────────────────────────────────────────────────────────────────────
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo

# ────────────────────────────────────────────────────────────────────────────
# OS junk
# ────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/